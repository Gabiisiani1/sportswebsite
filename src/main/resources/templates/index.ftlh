<!DOCTYPE html>
<html>
<head>
    <title>${title}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #1a1a2e;
            color: white;
            margin: 0;
            padding: 20px;
        }
        h1 {
            color: #e94560;
            text-align: center;
            font-size: 3em;
        }
        h2 {
            color: #e94560;
        }
        .card {
            background-color: #16213e;
            border-radius: 10px;
            padding: 20px;
            margin: 15px 0;
        }
        .sports-list {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }
        .sport-tag {
            background-color: #e94560;
            padding: 8px 20px;
            border-radius: 20px;
            font-weight: bold;
        }